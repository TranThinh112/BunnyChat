<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BunnyChat</title>
     
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Auth.css" asp-append-version="true" />

     
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    @* //icon boostrap  *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<body>
    <div class="auth-shell">

         <video autoplay muted loop playsinline class="bg-video">
            <source src="~/Video/BG.mp4" type="video/mp4">
        </video>
        
        <main role="main" class="pb-3">

@* 
           <div class="rabbit-wrapper">
                <div class="login-box">
                    <div class="rabbit" id="rabbit">
                        <div class="ear left-ear"></div>
                        <div class="ear right-ear"></div>

                        <div class="face">
                            <div class="eye left"></div>
                            <div class="eye right"></div>
                            <div class="nose"></div>
                        </div>
                    </div>
                </div>
            </div> *@
            
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - BunnyChat - <a asp-area="" asp-controller="Page" asp-action="Information" target="_blank">About Us</a>
        </div>
    </footer>

    
    <script type="module" src="~/js/Auth/Auth.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
