<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BunnyChat</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script>
        document.documentElement.dataset.theme = localStorage.getItem("bunny-theme")
            || (matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark");
    </script>
    <link rel="stylesheet" href="~/css/Chat.css" asp-append-version="true" />
</head>
<body style="display:none">
    @RenderBody()

    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script type="module" src="~/js/ChatAPI/ChatAction.js"></script>
    <script type="module" src="~/js/ChatAPI/Protect_Chat.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
