@{
    Layout = "~/Frontend/Views/Shared/AuthLayout.cshtml";
    ViewData["Title"] = "Auth";
}
<div class="auth-page">
        
    <div class="auth-card" id="authCard">

            <div class="form-container login-form">
                <div class="logo">
                    <img src="~/images/Logo.png" />
                </div>

                <h1 class="auth-title">Đăng nhập</h1>
                <p class="auth-subtitle">Chào mừng quay lại BunnyChat</p>

                <form class="auth-form" id="loginForm">
                    <div class="input-box">
                        <input id="username" name="UserName" type="text" placeholder=" ">
                        <label for="username">Username</label>
                        <span class="error-message"></span>
                    </div>
                   <div class="input-box password-box">
                        <input id="password" name="Password" type="password" placeholder=" ">
                        <label for="password">Password</label>
                        <span class="error-message"></span>

                    </div>
                    
                    <div id="loginError" class="error-box"></div>

                    <button type="submit" class="auth-btn"> Đăng nhập</button>
                </form>

                <div class="auth-forgot">
                    <a asp-area="" asp-controller="Page" asp-action="Forgot" target="_blank">Bạn quên mật khẩu ?</a>
                </div>
                
                <div class="auth-link">
                    Chưa có tài khoản?
                    <a href="#Signup" onclick="showSignup(); return false">Đăng ký</a>
                </div>
            </div>
        
        @* //form dang ky *@
            <div class="form-container signup-form">
                <div class="logo">
                    <img src="~/images/Logo.png" />
                </div>

                <h1 class="auth-title">Đăng ký</h1>
                <p class="auth-subtitle">Tạo tài khoản BunnyChat</p>

                <form class="auth-form" id="signupForm">

                    <div class="first-last">
                        <div class="input-box">
                            <input id="firstnameSignUp" name="FirstName" type="text" placeholder=" ">
                            <label>Họ</label>
                            <span class="error-message"></span>

                        </div>
                        <div class="input-box">
                            <input id="lastnameSignUp" name="LastName" type="text" placeholder=" ">
                            <label>Tên</label>
                            <span class="error-message"></span>
                        </div>
                    </div>

                    <div class="input-box">
                        <input id="usernameSignUp" name="UserName" type="text" placeholder=" ">
                        <label>Username</label>
                        <span class="error-message"></span>

                    </div>
                    <div class="input-box">
                        <input id="emailSignUp" name="Email" type="email" placeholder=" ">
                        <label>Email</label>
                        <span class="error-message"></span>

                    </div>
                    <div class="input-box">
                        <input id="passwordSignUp" name="Password" type="password" class="rabbit-password" placeholder=" ">
                        <label>Password</label>
                        <span class="error-message"></span>

                    </div>
                     <div id="signupError" class="error-box"></div>
                     
                    <button type="submit" class="auth-btn">Tạo tài khoản</button>
                </form>

                <div class="auth-link">
                    Đã có tài khoản?
                    <a href="#Login" onclick="showLogin(); return false">Đăng nhập</a>
                </div>
            </div>

        @* hieu ung chuyen dong *@
            <div class="overlay">
                <div class="flip-card">
                        <div class="flip-card-inner">
                            
                            @* //hinh anh mat truoc *@
                            <div class="flip-front">
                                <img src="~/images/Login.png" alt="login">
                            </div>

                            @* //hinh anh mat sau *@
                            <div class="flip-back">
                                <img src="~/images/Signup.png" alt="signup">
                            </div>
                        </div>
                    </div>
            </div>
    </div>
</div>
