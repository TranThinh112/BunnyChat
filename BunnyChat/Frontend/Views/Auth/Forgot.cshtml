@{
    Layout = "~/Frontend/Views/Shared/AuthLayout.cshtml";
    ViewData["Title"] = "Forgot";
}

<head>
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />

     
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    @* //icon boostrap  *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<div class="auth-page">
        
    <div class="forgot-card">

            <button class="icon-btn" onclick="window.location.href = '/'">
                <i class="bi bi-box-arrow-left"></i>
            </button>
    

            <div class="forgot-container forgot-form">


                <div class="logo">
                    <img src="~/images/Logo.png" />
                </div>

                <h1 class="auth-title">Forgot Pasword</h1>

                <form class="auth-form" menthod ="post" asp-controller="Auth" asp-action="Forgot">
                    <input name="UserName" type="text" placeholder="Username/ Email/ Phone">
                    <button type="submit" class="auth-btn"> Tiếp tục</button>
                </form>
            </div>
        
        
    </div>
</div>
