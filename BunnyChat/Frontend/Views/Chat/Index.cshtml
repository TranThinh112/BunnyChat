@{
    Layout = "~/Frontend/Views/Shared/_ChatLayout.cshtml";
    ViewData["Title"] = "Chat";
}

<div class="chat-app">
    @* phan sidebar ben trai  *@
 
    <aside class="chat-sidebar" id="chatSidebar">
        <header class="brand-card">
            <button class="notification-bell" type="button" id="openFriendRequestsBtn" aria-label="Thông báo lời mời kết bạn">
                <svg><use href="#icon-bell"></use></svg>
                <b id="friendRequestBadge" hidden>0</b>
            </button>
            <span class="brand-name"><span class="brand-bunny" aria-hidden="true"></span>BunnyChat</span>
            <span class="brand-actions">
                <button class="theme-toggle" type="button" role="switch" aria-checked="false" aria-label="Chuyển giao diện">
                    <i class="toggle-bunny"></i>
                </button>
                <button class="mobile-sidebar-close" id="closeSidebarBtn" type="button" aria-label="Đóng danh sách chat">×</button>
            </span>
        </header>

@* vùng search bạn bè *@
        <div class="sidebar-search">
            <button class="compose-button" type="button" id="openSearchBtn">
                <svg><use href="#icon-message"></use></svg>
                <span>Gửi tin nhắn mới</span>
            </button>

            <div class="search-box" id="searchBox">
                <input type="search" id="keyword" placeholder="Tìm người dùng..." autocomplete="off" />
                <button id="searchBtn" type="button" aria-label="Tìm kiếm"><svg><use href="#icon-search"></use></svg></button>
            </div>
            <div id="searchResult"></div>
        </div>
        <button class="search-dismiss" id="searchDismiss" type="button" aria-label="Đóng tìm kiếm"></button>

@* danh sách các conversation *@
        <div class="chat-lists">
            <section class="list-section">
                <div class="section-title"><span>Nhóm chat</span><span id="groupCount">0</span></div>
                <div class="list-content" id="groupList"></div>
                <button class="create-group-button" id="openGroupCreateBtn" type="button">+ Tạo nhóm chat</button>
            </section>

            <section class="list-section">
                <div class="section-title"><span>Bạn bè</span><span id="friendCount">0</span></div>
                <div class="friend-list-card" id="friendListCard">
                    <strong>Danh sách bạn bè</strong>
                    <small id="friendListSummary">Đang tải...</small>
                </div>
                <div class="list-content" id="friendList"></div>
            </section>
        </div>

@* thông tin của /me *@
        <footer class="profile-card">
            <span class="avatar avatar-purple" id="currentAvatar">U</span>
            <span class="profile-info">
                <strong id="currentDisplayname"></strong>
                <small id="currentUsername"></small>
            </span>
            <button id="openSettingsBtn" type="button" aria-label="Cài đặt"><svg><use href="#icon-settings"></use></svg></button>
            <button id="logoutBtn" type="button" aria-label="Đăng xuất"><svg><use href="#icon-logout"></use></svg></button>
        </footer>
    </aside>

    <main class="chat-main">
        <header class="chat-topbar">
            <button class="sidebar-toggle" id="sidebarToggle" type="button" aria-label="Mở danh sách chat"><svg><use href="#icon-sidebar"></use></svg></button>
            <span class="avatar avatar-purple chat-avatar" id="chatAvatar">?</span>
            <div class="chat-heading">
                <strong id="chatTitle">Chọn một cuộc trò chuyện</strong>
                <small id="chatStatus">Tin nhắn sẽ được tải từ máy chủ</small>
            </div>
            <button class="info-button" id="groupInfoButton" type="button" aria-label="Thông tin nhóm" disabled>
                <svg><use href="#icon-info"></use></svg>
            </button>
        </header>

        <section class="message-area" id="messageArea"></section>

@* ô nhập tin nhắn *@
        <form class="message-composer" id="messageForm">
            <input id="messageInput" type="text" placeholder="Chọn cuộc trò chuyện để nhắn tin..." autocomplete="off" disabled />
            <button class="send-button" type="submit" aria-label="Gửi tin nhắn" disabled><svg><use href="#icon-send"></use></svg></button>
        </form>
    </main>
</div>

@* phần thông tin của nhóm *@
<aside class="group-info" id="groupInfo" aria-hidden="true">
    <button class="group-info-backdrop" type="button" data-close-group-info aria-label="Đóng"></button>
    <section class="group-info-panel">
        <header>
            <strong>Thông tin nhóm</strong>
            <button type="button" data-close-group-info aria-label="Đóng">×</button>
        </header>
        <div id="groupInfoContent"></div>
    </section>
</aside>

@* thông tin cá nhân khi chat 1:1 *@
<div class="profile-modal" id="profileModal" aria-hidden="true">
    <button class="profile-modal-backdrop" type="button" data-close-profile aria-label="Đóng"></button>
    <section class="profile-modal-card" role="dialog" aria-modal="true" aria-labelledby="profileModalName">
        <button class="profile-modal-close" type="button" data-close-profile aria-label="Đóng">×</button>
        <div class="profile-modal-content" id="profileModalContent"></div>
    </section>
</div>

@* phần setting thông tin của /me *@
<div class="friend-modal" id="settingsModal" aria-hidden="true">
    <button class="friend-modal-backdrop" type="button" data-close-settings aria-label="Đóng"></button>
    <section class="friend-modal-card settings-modal-card" role="dialog" aria-modal="true" aria-labelledby="settingsTitle">
        <header>
            <span>
                <strong id="settingsTitle">Cài đặt tài khoản</strong>
                <small>Cập nhật thông tin /me và đổi màu logo</small>
            </span>
            <button type="button" data-close-settings aria-label="Đóng">×</button>
        </header>

        <form class="modal-form settings-form" id="settingsForm">
            <div class="settings-grid">
                <label>
                    <span>Họ</span>
                    <input id="settingsFirstName" type="text" autocomplete="given-name" />
                </label>
                <label>
                    <span>Tên</span>
                    <input id="settingsLastName" type="text" autocomplete="family-name" />
                </label>
            </div>

            <label>
                <span>Nickname</span>
                <input id="settingsNickname" type="text" autocomplete="nickname" />
            </label>

            <label>
                <span>Số điện thoại</span>
                <input id="settingsPhone" type="tel" placeholder="VD: 0912345678" autocomplete="tel" />
            </label>

            <label>
                <span>Avatar URL</span>
                <input id="settingsAvatarUrl" type="url" placeholder="https://..." />
            </label>

            <label>
                <span>Bio</span>
                <textarea id="settingsBio" maxlength="240" placeholder="Giới thiệu ngắn về bạn"></textarea>
            </label>

            <div class="logo-color-panel">
                <span>
                    <strong>Màu logo</strong>
                    <small>Random màu giao diện BunnyChat</small>
                </span>
                <button class="friend-action secondary" id="randomLogoColorBtn" type="button">Random màu</button>
            </div>

            <div class="modal-actions">
                <button class="friend-action secondary" type="button" data-close-settings>Hủy</button>
                <button class="friend-action" type="submit">Lưu thay đổi</button>
            </div>
        </form>
    </section>
</div>

@* //quản lý lời mời kết bạn *@
<div class="friend-modal" id="friendModal" aria-hidden="true">
    <button class="friend-modal-backdrop" type="button" data-close-friend-modal aria-label="Đóng"></button>
    <section class="friend-modal-card" role="dialog" aria-modal="true" aria-labelledby="friendModalTitle">
        <header>
            <span>
                <strong id="friendModalTitle">Lời mời kết bạn</strong>
                <small>Quản lý lời mời đã nhận và đã gửi</small>
            </span>
            <button type="button" data-close-friend-modal aria-label="Đóng">×</button>
        </header>

        <div class="friend-tabs">
            <button class="friend-tab active" type="button" data-friend-tab="received">Đã nhận</button>
            <button class="friend-tab" type="button" data-friend-tab="sent">Đã gửi</button>
        </div>

        <div class="friend-request-list" id="friendRequestList"></div>
    </section>
</div>


@* //phần nhân content gửi kết bạn *@
<div class="friend-modal" id="friendRequestMessageModal" aria-hidden="true">
    <button class="friend-modal-backdrop" type="button" data-close-friend-message aria-label="Đóng"></button>
    <section class="friend-modal-card compact-modal" role="dialog" aria-modal="true" aria-labelledby="friendMessageTitle">
        <header>
            <span>
                <strong id="friendMessageTitle">Gửi lời mời kết bạn</strong>
                <small id="friendMessageSubtitle">Nhập lời nhắn ngắn gửi kèm lời mời</small>
            </span>
            <button type="button" data-close-friend-message aria-label="Đóng">×</button>
        </header>

        <form class="modal-form" id="friendRequestMessageForm">
            <textarea id="friendRequestMessageInput" maxlength="180" placeholder="VD: Kết bạn nhé ?"></textarea>
            <div class="modal-actions">
                <button class="friend-action secondary" type="button" data-close-friend-message>Hủy</button>
                <button class="friend-action" type="submit">Gửi lời mời</button>
            </div>
        </form>
    </section>
</div>

@* //phần tạo nhóm chat *@
<div class="friend-modal" id="groupCreateModal" aria-hidden="true">
    <button class="friend-modal-backdrop" type="button" data-close-group-create aria-label="Đóng"></button>
    <section class="friend-modal-card" role="dialog" aria-modal="true" aria-labelledby="groupCreateTitle">
        <header>
            <span>
                <strong id="groupCreateTitle">Tạo nhóm chat</strong>
                <small>Chọn bạn bè và đặt tên nhóm</small>
            </span>
            <button type="button" data-close-group-create aria-label="Đóng">×</button>
        </header>

        <form class="modal-form" id="groupCreateForm">
            <label class="field-label" for="groupNameInput">Tên nhóm</label>
            <input id="groupNameInput" type="text" maxlength="60" placeholder="VD: Nhóm Backend Dev" autocomplete="off" />
            <small class="field-error" id="groupNameError" aria-live="polite"></small>

            <div class="field-label">Thành viên</div>
            <div class="member-picker" id="groupMemberPicker"></div>
            <small class="field-error" id="groupMembersError" aria-live="polite"></small>

            <div class="modal-actions">
                <button class="friend-action secondary" type="button" data-close-group-create>Hủy</button>
                <button class="friend-action" type="submit">Tạo nhóm</button>
            </div>
        </form>
    </section>
</div>

@* kho icon  *@
