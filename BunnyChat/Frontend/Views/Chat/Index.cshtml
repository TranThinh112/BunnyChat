@{
    Layout = "~/Frontend/Views/Shared/_ChatLayout.cshtml";
    ViewData["Title"] = "Chat";
}


<div class="d-flex vh-100">

    <!-- Sidebar -->
    <div class="bg-light border-end p-3" style="width:280px;">

       <div class="chat-header">
            Xin chào, <span id="currentUsername"></span> <br />
            DisplayName: <span id="currentDisplayname"></span>
        </div>
               //test
    <input type="text"
           id="keyword"
           class="form-control mb-2"
           placeholder="Nhập từ khóa">

    <button id="searchBtn"
            class="btn btn-primary">
        Tìm kiếm
    </button>

    <div id="searchResult" class="mt-3"></div>
</div>

        <ul class="nav flex-column mt-4">

            <li class="nav-item">
                <a class="nav-link text-dark" href="#">Playground</a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-dark" href="#">Models</a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-dark" href="#">Documentation</a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-dark" href="#">Settings</a>
            </li>
        </ul>
        <div class="p-3">

     
        <button id="logoutBtn" type="button" class="chat-btn"> Đăng xuất</button>
    </div>

    <!-- Content -->
    <div class="flex-grow-1 p-4">
        <h2>Chat Window</h2>
            
    </div>

</div>